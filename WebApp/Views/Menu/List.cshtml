@using WebApp.Models
@using System.Linq

@{
    Layout = "_Layout";
    ViewBag.Title = "Список пунктов меню";
}

<div class="page split">
    <aside class="side">
        <nav class="side-menu">
            <a href="/home" style="padding: 12px 16px; background: white; border: 1px solid #ddd; border-radius: 4px; text-decoration: none; color: #0066cc; cursor: pointer; font-size: 14px; transition: all 0.2s; display: block; margin-bottom: 8px;">← На главную</a>
            
            <div class="accordion-group">
                <div class="accordion-header active" onclick="toggleAccordion(this)">
                    <span class="accordion-arrow">▼</span>
                    <span>Администрирование</span>
                </div>
                <div class="accordion-content active">
                    <a class="accordion-item" href="/admin">Админ панель</a>
                    <a class="accordion-item" href="/menu/additem">Добавить пункт меню</a>
                    <a class="accordion-item" href="/menu/list">Список пунктов меню</a>
                </div>
            </div>
            
            <div class="accordion-group">
                <div class="accordion-header" onclick="toggleAccordion(this)">
                    <span class="accordion-arrow">►</span>
                    <span>Управление Юзарями</span>
                </div>
                <div class="accordion-content">
                    <a class="accordion-item" href="/users/adduser">Добавить пользователя</a>
                    <a class="accordion-item" href="/users/list">Пользователи</a>
                    <a class="accordion-item" href="/users/managerights">Права</a>
                </div>
            </div>
            
            <div class="accordion-group">
                <div class="accordion-header" onclick="toggleAccordion(this)">
                    <span class="accordion-arrow">►</span>
                    <span>Логи</span>
                </div>
                <div class="accordion-content">
                    <a class="accordion-item" href="/logs/logins">Логи входов</a>
                </div>
            </div>
            
            <a href="/account/logout" onclick="if(!confirm('Вы уверены?')) return false;" class="accordion-item" style="padding: 12px 16px; background: white; border: 1px solid #ddd; border-radius: 4px; margin-top: 8px;">Выход</a>
        </nav>
    </aside>
    <main class="content">
        <h1>Список пунктов меню</h1>

        @{
            var adminItems = ViewBag.AdminItems as List<IGrouping<string, MenuItem>>;
            var frontendItems = ViewBag.FrontendItems as List<IGrouping<string, MenuItem>>;
            var hasItems = (adminItems?.Any() ?? false) || (frontendItems?.Any() ?? false);
        }

        @if (hasItems)
        {
            <!-- Раздел АДМИНКА -->
            <div style="margin-bottom: 40px;">
                <h2 style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 15px 20px; border-radius: 8px; font-size: 20px;">⚙️ АДМИНКА</h2>
                
                @if (adminItems?.Any() ?? false)
                {
                    @foreach (var group in adminItems)
                    {
                        <div style="margin: 20px 0; background: white; border: 2px solid #667eea; border-radius: 8px; overflow: hidden;">
                            <div style="background: #f0f3ff; padding: 12px 20px; font-weight: bold; color: #667eea; font-size: 16px;">
                                📁 @group.Key
                            </div>
                            <table class="table" style="margin: 0;">
                                <thead>
                                    <tr>
                                        <th style="width: 60px;">ID</th>
                                        <th>Название</th>
                                        <th>URL</th>
                                        <th style="width: 80px;">Порядок</th>
                                        <th style="width: 100px;">Статус</th>
                                        <th style="width: 120px;">Действия</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in group.OrderBy(i => i.Order))
                                    {
                                        <tr>
                                            <td>@item.Id</td>
                                            <td><strong>@item.Name</strong></td>
                                            <td><code style="background: #f5f5f5; padding: 2px 6px; border-radius: 3px; font-size: 12px;">@item.Url</code></td>
                                            <td>@item.Order</td>
                                            <td>
                                                @if (item.IsActive)
                                                {
                                                    <span style="color: #3c3;">● Активен</span>
                                                }
                                                else
                                                {
                                                    <span style="color: #999;">○ Неактивен</span>
                                                }
                                            </td>
                                            <td>
                                                <form method="post" action="/menu/delete/@item.Id" style="display: inline;">
                                                    <button type="submit" onclick="return confirm('Удалить пункт меню?');" style="padding: 6px 12px; background: #c33; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 12px;">Удалить</button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                }
                else
                {
                    <p style="padding: 20px; color: #999;">Нет пунктов меню для админки</p>
                }
            </div>

            <!-- Раздел ФРОНТ -->
            <div style="margin-bottom: 40px;">
                <h2 style="background: linear-gradient(135deg, #84fab0 0%, #8fd3f4 100%); color: #333; padding: 15px 20px; border-radius: 8px; font-size: 20px;">🎯 ФРОНТ</h2>
                
                @if (frontendItems?.Any() ?? false)
                {
                    @foreach (var group in frontendItems)
                    {
                        <div style="margin: 20px 0; background: white; border: 2px solid #84fab0; border-radius: 8px; overflow: hidden;">
                            <div style="background: #f0fff8; padding: 12px 20px; font-weight: bold; color: #2d9d6d; font-size: 16px;">
                                📁 @group.Key
                            </div>
                            <table class="table" style="margin: 0;">
                                <thead>
                                    <tr>
                                        <th style="width: 60px;">ID</th>
                                        <th>Название</th>
                                        <th>URL</th>
                                        <th style="width: 80px;">Порядок</th>
                                        <th style="width: 100px;">Статус</th>
                                        <th style="width: 120px;">Действия</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in group.OrderBy(i => i.Order))
                                    {
                                        <tr>
                                            <td>@item.Id</td>
                                            <td><strong>@item.Name</strong></td>
                                            <td><code style="background: #f5f5f5; padding: 2px 6px; border-radius: 3px; font-size: 12px;">@item.Url</code></td>
                                            <td>@item.Order</td>
                                            <td>
                                                @if (item.IsActive)
                                                {
                                                    <span style="color: #3c3;">● Активен</span>
                                                }
                                                else
                                                {
                                                    <span style="color: #999;">○ Неактивен</span>
                                                }
                                            </td>
                                            <td>
                                                <form method="post" action="/menu/delete/@item.Id" style="display: inline;">
                                                    <button type="submit" onclick="return confirm('Удалить пункт меню?');" style="padding: 6px 12px; background: #c33; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 12px;">Удалить</button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                }
                else
                {
                    <p style="padding: 20px; color: #999;">Нет пунктов меню для фронта</p>
                }
            </div>
        }
        else
        {
            <p>Нет созданных пунктов меню.</p>
        }

        <a href="/menu/additem" class="btn btn-primary">Добавить пункт меню</a>
        <a href="/admin" class="btn btn-secondary">Назад в админку</a>
    </main>
</div>

<style>
.table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 20px;
    font-size: 14px;
    background: white;
    border: 1px solid #ddd;
    border-radius: 4px;
}

.table thead {
    background: #f5f5f5;
}

.table th {
    padding: 12px 16px;
    text-align: left;
    font-weight: 600;
    border-bottom: 2px solid #ddd;
}

.table td {
    padding: 12px 16px;
    border-bottom: 1px solid #ddd;
}

.table tbody tr:hover {
    background: #f9f9f9;
}

.btn {
    padding: 12px 24px;
    border: none;
    border-radius: 4px;
    text-decoration: none;
    font-size: 14px;
    cursor: pointer;
    display: inline-block;
    margin-right: 10px;
    margin-bottom: 10px;
}

.btn-primary {
    background: #0066cc;
    color: white;
}

.btn-primary:hover {
    background: #0052a3;
}

.btn-secondary {
    background: #ddd;
    color: #333;
}

.btn-secondary:hover {
    background: #ccc;
}
</style>
