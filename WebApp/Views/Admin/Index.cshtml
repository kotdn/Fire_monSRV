@using WebApp.Models
@using System.Linq

@{
    Layout = "_Layout";
    ViewBag.Title = "Админпанель";
}

<div class="page split">
    <!-- Боковое меню -->
    <aside class="admin-sidebar">
        <div style="padding: 15px 0;">
            <form method="post" action="/account/logout" style="margin: 0 0 15px 0;">
                <button type="submit" style="width: 100%; padding: 10px; background: #f44336; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 13px; transition: all 0.2s;" onmouseover="this.style.background='#d32f2f'" onmouseout="this.style.background='#f44336'">
                    🚪 Выход
                </button>
            </form>
            <a href="/home" style="display: block; padding: 10px; background: #2196F3; color: white; border: none; border-radius: 4px; text-decoration: none; text-align: center; font-size: 13px; transition: all 0.2s;" onmouseover="this.style.background='#1976D2'" onmouseout="this.style.background='#2196F3'">
                🏠 На главную
            </a>
        </div>

        @if (ViewBag.MenuItems is List<IGrouping<string, MenuItem>> groups && groups.Count > 0)
        {
            @foreach (var group in groups)
            {
                <div style="margin-bottom: 15px;">
                    <div style="background: #0066cc; color: white; padding: 10px 12px; font-weight: bold; font-size: 12px; border-radius: 4px; text-transform: uppercase; margin-bottom: 8px;">
                        @group.Key
                    </div>
                    <div style="display: flex; flex-direction: column; gap: 5px;">
                        @foreach (var item in group.OrderBy(i => i.Order))
                        {
                            <a href="@item.Url" style="display: block; padding: 8px 12px; background: white; border: 1px solid #ddd; border-left: 3px solid #0066cc; border-radius: 4px; text-decoration: none; color: #333; font-size: 13px; transition: all 0.2s; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" 
                               onmouseover="this.style.background='#f0f7ff'; this.style.borderLeftColor='#ff6b6b'" 
                               onmouseout="this.style.background='white'; this.style.borderLeftColor='#0066cc'"
                               title="@item.Name">
                                @item.Name
                            </a>
                        }
                    </div>
                </div>
            }
        }
    </aside>

    <!-- Основной контент -->
    <main class="content" style="flex: 1;">
        <div class="content-topbar">
            <a class="btn-link" href="/home">На главную</a>
        </div>

        <h1>Администрирование</h1>

        <div style="background: #f0f7ff; border-left: 4px solid #0066cc; padding: 20px; border-radius: 4px; margin-top: 20px;">
            <h3 style="margin: 0 0 10px 0; color: #0066cc;">⚙️ Панель администратора</h3>
            <p style="margin: 0; color: #666; line-height: 1.6;">
                Выберите пункт меню слева для управления системой.
            </p>
        </div>

        @if (ViewBag.MenuItems is List<IGrouping<string, MenuItem>> groupsEmpty && groupsEmpty.Count == 0)
        {
            <div style="margin-top: 30px;">
                <p style="color: #999; font-size: 13px; text-align: center; padding: 40px 20px;">
                    Пункты меню не загружены
                </p>
            </div>
        }
        else if (!(ViewBag.MenuItems is List<IGrouping<string, MenuItem>>))
        {
            <div style="margin-top: 30px;">
                <p style="color: #999; font-size: 13px; text-align: center; padding: 40px 20px;">
                    ← Выберите пункт из меню слева
                </p>
            </div>
        }
    </main>
</div>
