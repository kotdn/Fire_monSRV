@{
    Layout = "_Layout";
    ViewBag.Title = "Добавить пользователя";
}

<div class="page split">
    <aside class="side">
    <aside class="side">
        <nav class="side-menu">
            <a href="/home" style="padding: 12px 16px; background: white; border: 1px solid #ddd; border-radius: 4px; text-decoration: none; color: #0066cc; cursor: pointer; font-size: 14px; transition: all 0.2s; display: block; margin-bottom: 8px;">← На главную</a>
            
            <div class="accordion-group">
                <div class="accordion-header" onclick="toggleAccordion(this)">
                    <span class="accordion-arrow">►</span>
                    <span>Администрирование</span>
                </div>
                <div class="accordion-content">
                    <a class="accordion-item" href="/admin">Админ панель</a>
                    <a class="accordion-item" href="/menu/additem">Добавить пункт меню</a>
                    <a class="accordion-item" href="/menu/list">Список пунктов меню</a>
                </div>
            </div>
            
            <div class="accordion-group">
                <div class="accordion-header active" onclick="toggleAccordion(this)">
                    <span class="accordion-arrow">▼</span>
                    <span>Управление Юзарями</span>
                </div>
                <div class="accordion-content active">
                    <a class="accordion-item" href="/users/adduser">Добавить пользователя</a>
                    <a class="accordion-item" href="/users/list">Пользователи</a>
                    <a class="accordion-item" href="/users/managerights">Права</a>
                </div>
            </div>
            
            <div class="accordion-group">
                <div class="accordion-header" onclick="toggleAccordion(this)">
                    <span class="accordion-arrow">►</span>
                    <span>Логи</span>
                </div>
                <div class="accordion-content">
                    <a class="accordion-item" href="/logs/logins">Логи входов</a>
                </div>
            </div>
            
            <a href="/account/logout" onclick="if(!confirm('Вы уверены?')) return false;" class="accordion-item" style="padding: 12px 16px; background: white; border: 1px solid #ddd; border-radius: 4px; margin-top: 8px;">Выход</a>
        </nav>
    </aside>
    </aside>
    <main class="content">
        <h1>Добавить пользователя</h1>

        @if (!string.IsNullOrEmpty(ViewBag.Error))
        {
            <div class="alert alert-error">@ViewBag.Error</div>
        }

        @if (!string.IsNullOrEmpty(ViewBag.Success))
        {
            <div class="alert alert-success">@ViewBag.Success</div>
        }

        <form method="post" class="form">
            <div class="form-group">
                <label for="username">Имя пользователя:</label>
                <input type="text" id="username" name="username" required placeholder="Введите имя пользователя">
            </div>

            <div class="form-group">
                <label for="password">Пароль:</label>
                <input type="password" id="password" name="password" required placeholder="Введите пароль">
            </div>

            <div class="form-group">
                <label for="passwordConfirm">Подтверждение пароля:</label>
                <input type="password" id="passwordConfirm" name="passwordConfirm" required placeholder="Подтвердите пароль">
            </div>

            <div class="form-group">
                <label>
                    <input type="checkbox" name="isAdmin" value="true">
                    Администратор
                </label>
            </div>

            <button type="submit" class="btn btn-primary">Создать пользователя</button>
            <a href="/home" class="btn btn-secondary">Отмена</a>
        </form>
    </main>
</div>

<style>
.alert {
    padding: 12px 16px;
    margin-bottom: 20px;
    border-radius: 4px;
    border-left: 4px solid;
}

.alert-error {
    background: #fee;
    color: #c33;
    border-color: #c33;
}

.alert-success {
    background: #efe;
    color: #3c3;
    border-color: #3c3;
}

.form {
    max-width: 400px;
}

.form-group {
    margin-bottom: 20px;
    display: flex;
    flex-direction: column;
}

.form-group label {
    margin-bottom: 8px;
    font-weight: 500;
    color: #333;
}

.form-group input[type="text"],
.form-group input[type="password"] {
    padding: 10px 12px;
    border: 1px solid #ddd;
    border-radius: 4px;
    font-size: 14px;
}

.form-group input[type="checkbox"] {
    margin-right: 8px;
    cursor: pointer;
}

.form-group label:has(input[type="checkbox"]) {
    flex-direction: row;
    align-items: center;
}

.btn {
    padding: 12px 24px;
    border: none;
    border-radius: 4px;
    text-decoration: none;
    font-size: 14px;
    cursor: pointer;
    display: inline-block;
    margin-right: 10px;
}

.btn-primary {
    background: #0066cc;
    color: white;
}

.btn-primary:hover {
    background: #0052a3;
}

.btn-secondary {
    background: #ddd;
    color: #333;
}

.btn-secondary:hover {
    background: #ccc;
}
</style>
